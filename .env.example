# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/smart_cdp_dev

# Environment
NODE_ENV=production

# Application Secrets (CRITICAL: Must be 32+ characters for production)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-here-minimum-32-characters-required-for-production
SESSION_SECRET=your-session-secret-key-here-minimum-32-characters-required-for-production

# External Services (Optional)
OPENAI_API_KEY=your-openai-api-key
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_VERIFIED_SENDER=your-verified-sender@email.com

# Deployment Configuration
DEPLOYMENT_ENV=development
ENABLE_CACHE=false
DEBUG_MODE=true

# Database Migration Settings
DB_MIGRATION_AUTO_APPLY=false
DB_BACKUP_BEFORE_MIGRATE=true