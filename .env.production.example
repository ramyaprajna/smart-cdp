# Production Environment Configuration
# Copy this to .env in your production environment

# Environment
NODE_ENV=production

# Database (Update with your production database URL)
DATABASE_URL=postgresql://prod_user:secure_password@prod-db-host:5432/smart_cdp_prod

# Security Secrets (REPLACE WITH GENERATED VALUES - 32+ characters required)
# Generate with: openssl rand -base64 32
JWT_SECRET=h8K2mP9qR7sT3vW6xY1zE4fG8hJ2mN5qR7sT9vW2xY5z
SESSION_SECRET=B9dF2gH5jK8mP1qT4vW7yZ0aE3fG6hJ9mP2qT5vW8yZ1

# External Services (Optional - Update with production keys)
OPENAI_API_KEY=your-production-openai-api-key
SENDGRID_API_KEY=your-production-sendgrid-api-key
SENDGRID_VERIFIED_SENDER=noreply@yourdomain.com

# Production Configuration
DEPLOYMENT_ENV=production
ENABLE_CACHE=true
DEBUG_MODE=false

# Database Migration Settings (Safe for production)
DB_MIGRATION_AUTO_APPLY=false
DB_BACKUP_BEFORE_MIGRATE=true